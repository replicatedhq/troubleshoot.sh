{
  "name": "troubleshoot-docs",
  "version": "0.0.0",
  "private": true,
  "scripts": {
    "docusaurus": "docusaurus",
    "start": "docusaurus start --port 3001",
    "dev": "docusaurus start --port 3001",
    "prebuild": "npm run generate-llms",
    "build": "docusaurus build",
    "generate-llms": "node static/js/generate-llms.js",
    "build:analyze": "docusaurus build --bundle-analyzer",
    "swizzle": "docusaurus swizzle",
    "deploy": "docusaurus deploy",
    "clear": "docusaurus clear",
    "serve": "docusaurus serve --port 3001",
    "serve:build": "docusaurus serve --build --port 3001",
    "write-translations": "docusaurus write-translations",
    "write-heading-ids": "docusaurus write-heading-ids",
    "typecheck": "tsc",
    "lint": "eslint src --ext .js,.jsx,.ts,.tsx",
    "lint:fix": "eslint src --ext .js,.jsx,.ts,.tsx --fix"
  },
  "dependencies": {
    "@docusaurus/core": "3.9.2",
    "@docusaurus/preset-classic": "3.9.2",
    "@docusaurus/theme-search-algolia": "^3.8.1",
    "@mdx-js/react": "^3.1.1",
    "clsx": "^2.0.0",
    "prism-react-renderer": "^2.3.0",
    "react": "^19.2.4",
    "react-dom": "^19.2.4"
  },
  "devDependencies": {
    "@docusaurus/module-type-aliases": "3.9.2",
    "@docusaurus/tsconfig": "3.9.2",
    "@docusaurus/types": "3.9.2",
    "typescript": "~5.9.3"
  },
  "browserslist": {
    "production": [
      ">0.5%",
      "not dead",
      "not op_mini all"
    ],
    "development": [
      "last 3 chrome version",
      "last 3 firefox version",
      "last 5 safari version"
    ]
  },
  "engines": {
    "node": ">=24.0"
  },
  "resolutions": {
    "webpack-dev-server": ">=5.2.1",
    "uuid": ">=14.0.0",
    "brace-expansion": ">=1.1.13",
    "follow-redirects": ">=1.16.0",
    "lodash": ">=4.18.0",
    "path-to-regexp": ">=0.1.13",
    "serialize-javascript": ">=7.0.5",
